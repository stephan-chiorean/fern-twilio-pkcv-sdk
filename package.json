{
  "name": "fern-twilio-pkcv-sdk",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "sdks/typescript",
    "examples/test-app"
  ],
  "scripts": {
    "build:sdk": "npm run build --workspace sdks/typescript",
    "example:start": "npm run build:sdk && npm run start --workspace examples/test-app",
    "example:dry-run": "npm run build:sdk && npm run start:dry-run --workspace examples/test-app",
    "test:e2e": "npm run example:dry-run",
    "publish:dry-run": "npm run publish:dry-run --workspace sdks/typescript",
    "publish:sdk": "npm run publish:sdk --workspace sdks/typescript",
    "test:signing": "node scripts/test-pkcv.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "dotenv": "^17.4.1",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.17",
    "vitest": "^3.2.4"
  }
}
