{
  "name": "fern-twilio-pkcv-sdk",
  "version": "0.1.0-alpha.0",
  "description": "Twilio Verify TypeScript SDK generated with Fern and extended with PKCV custom auth.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "publish:dry-run": "npm publish --dry-run --access public --cache ../../.npm-cache",
    "publish:sdk": "npm publish --access public --cache ../../.npm-cache"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.17",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  }
}
